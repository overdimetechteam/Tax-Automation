# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — use DATABASE_URL for PostgreSQL (Render), or individual MySQL vars for local
# PostgreSQL (Render / production)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=noreply@taxautomation.lk

# eSMS (Dialog Enterprise Marketplace) — bulk SMS gateway
ESMS_ENABLED=True
ESMS_API_KEY=your_esms_bearer_token
# Only needed if ESMS_API_KEY is not set (fallback login flow)
ESMS_USERNAME=your_esms_username
ESMS_PASSWORD=your_esms_password
# Optional — leave blank to use the account's default registered mask
ESMS_SENDER_ADDRESS=
